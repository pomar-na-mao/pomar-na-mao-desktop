{
  "name": "pomar-na-mao-desktop",
  "version": "1.4.0",
  "scripts": {
    "ng": "ng",
    "start": "npm run tauri:serve",
    "web:serve": "ng serve -o",
    "web:build": "ng build --base-href ./",
    "web:dev": "npm run web:build",
    "web:prod": "npm run web:build -- -c production",
    "tauri": "tauri",
    "tauri:serve": "node -e \"require('fs').mkdirSync('dist/browser', {recursive:true})\" && tauri dev",
    "tauri:bundle": "npm run web:prod && tauri build",
    "test": "ng test --watch=false",
    "test:watch": "ng test",
    "test:preview": "npx vite preview --outDir test-results/vitest",
    "version": "conventional-changelog -i CHANGELOG.md -s -r 0 && git add CHANGELOG.md",
    "lint": "ng lint"
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@tauri-apps/api": "2.11.0",
    "leaflet": "^1.9.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "21.3.1",
    "@angular-eslint/eslint-plugin": "21.3.1",
    "@angular-eslint/eslint-plugin-template": "21.3.1",
    "@angular-eslint/schematics": "21.3.1",
    "@angular-eslint/template-parser": "21.3.1",
    "@angular/build": "^21.2.9",
    "@angular/cli": "^21.2.9",
    "@angular/compiler-cli": "^21.2.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@tauri-apps/cli": "^2.11.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "25.6.0",
    "@typescript-eslint/eslint-plugin": "8.59.1",
    "@typescript-eslint/parser": "8.59.1",
    "@vitest/browser-playwright": "4.1.5",
    "@vitest/coverage-v8": "4.1.5",
    "@vitest/ui": "^4.1.5",
    "conventional-changelog": "7.2.0",
    "eslint": "9.39.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsdoc": "62.9.0",
    "eslint-plugin-prefer-arrow": "1.2.3",
    "jsdom": "28.1.0",
    "npm-run-all": "4.1.5",
    "playwright": "1.59.1",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "vitest": "4.1.5"
  }
}
