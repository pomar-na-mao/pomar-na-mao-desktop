{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Pomar na mão",
  "version": "1.4.0",
  "identifier": "com.lspeixoto.pomarnamaodesktop",
  "build": {
    "frontendDist": "../dist/browser",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "npm run web:serve",
    "beforeBuildCommand": "npm run web:prod"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Pomar na mão",
        "width": 1230,
        "height": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "",
    "category": "DeveloperTool",
    "shortDescription": "",
    "longDescription": "",
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "",
      "exceptionDomain": "",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
